<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#75A8A9">

    <!-- Título -->
    <TextView
        android:id="@+id/tvTituloMetodoPago"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Método de Pago"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#333333"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- CARD YAPE -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardYape"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:strokeColor="@android:color/transparent"
        app:strokeWidth="0dp"
        android:background="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/tvTituloMetodoPago"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imgQrYape"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:src="@drawable/yape"
                android:contentDescription="QR Yape" />

            <TextView
                android:id="@+id/tvYape"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pagar con Yape"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- CARD PLIN -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPlin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:strokeColor="@android:color/transparent"
        app:strokeWidth="0dp"
        android:background="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/cardYape"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imgQrPlin"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:src="@drawable/plin"
                android:contentDescription="QR Plin" />

            <TextView
                android:id="@+id/tvPlin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pagar con Plin"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- BOTÓN FINALIZAR -->
    <Button
        android:id="@+id/btnFinalizarPedido"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Finalizar Pedido"
        android:textSize="18sp"
        android:layout_marginTop="20dp"
        android:textColor="@android:color/white"
        android:backgroundTint="#4B1F22"
        app:layout_constraintTop_toBottomOf="@id/cardPlin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
