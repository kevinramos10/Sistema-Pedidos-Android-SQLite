<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#9AB67C"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="8dp">

        <ImageView
            android:id="@+id/imgClientePlatillo"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:scaleType="centerCrop"
            android:src="@drawable/comida" />

        <TextView
            android:id="@+id/tvNombrePlatillo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="Nombre del Platillo"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStockPlatillo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Stock: 10"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvPrecioPlatillo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="S/ 12.00"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnMenos"
                android:layout_width="63dp"
                android:layout_height="40dp"
                android:text="−" />

            <TextView
                android:id="@+id/tvCantidad"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="0" />

            <Button
                android:id="@+id/btnMas"
                android:layout_width="57dp"
                android:layout_height="40dp"
                android:text="+" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
